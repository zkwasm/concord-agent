{
  "name": "concord-agent",
  "version": "0.1.2",
  "description": "Host a coding agent (claude/codex/gemini/…) in a Concord room over ACP. Resident session, idle = zero tokens, token budget, IM control.",
  "type": "module",
  "bin": {
    "concord": "src/concord.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src/**/*.mjs",
    "!src/**/*.test.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test src/*.test.mjs",
    "start": "node src/concord.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.28.1",
    "@larksuiteoapi/node-sdk": "^1.68.0"
  },
  "keywords": [
    "concord",
    "acp",
    "agent-client-protocol",
    "coding-agent",
    "claude",
    "codex",
    "ai",
    "cli"
  ],
  "author": "Concord",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zkwasm/concord-agent.git"
  },
  "homepage": "https://github.com/zkwasm/concord-agent#readme",
  "bugs": {
    "url": "https://github.com/zkwasm/concord-agent/issues"
  }
}
